# Browser-exposed Vite variables.
# Copy this file to web/.env.local for local development.

# Socket.IO signaling server used by shared listening rooms.
VITE_SIGNAL_URL=http://localhost:8788

# Local development endpoints used when selecting the local network preset.
VITE_LOCAL_WS_URL=ws://localhost:9944
VITE_LOCAL_ETH_RPC_URL=http://localhost:8545

# Optional global Polkadot WS override. Leave empty to use local/testnet defaults.
# VITE_WS_URL=

# Paseo Bulletin Chain RPC used for metadata JSON publication.
VITE_BULLETIN_WS_URL=wss://paseo-bulletin-rpc.polkadot.io

# Backend API service URL.
# Used by production backend-backed flows as they land.
# VITE_DOTIFY_API_URL=http://localhost:8790

# Pinata direct-browser upload — demo/local mode only.
# Use a restricted Pinata JWT (upload-only scope). Do NOT use an unrestricted token.
# Server-side Pinata uploads are tracked by backlog Ticket 02.
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=https://paseo-ipfs.polkadot.io
VITE_IPFS_READ_GATEWAYS=https://paseo-ipfs.polkadot.io,https://ipfs.io,https://dweb.link

# Best-effort browser-side audio encryption secret.
# Must be 32 bytes as hex. It is bundled into the frontend, so treat it as
# demo protection rather than production DRM.
# VITE_CONTENT_SECRET=

# Node-only variables used by npm scripts in web/.
SIGNAL_PORT=8788
SIGNAL_HOST=0.0.0.0
SIGNAL_ORIGIN=http://localhost:5273
BULLETIN_ACCOUNT=Alice
