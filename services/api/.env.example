# Dotify API — backend service environment variables.
# Copy this file to services/api/.env for local development.

# Port the API server listens on.
API_PORT=8790

# Frontend origin allowed by CORS.
API_ORIGIN=http://localhost:5273

# Paseo Asset Hub EVM RPC (used for future on-chain access checks).
PASEO_ASSET_HUB_RPC=https://services.polkadothub-rpc.com/testnet

# Deployed contract addresses (used for future access verification).
DOTIFY_FACTORY_ADDRESS=
DOTIFY_DIRECTORY_ADDRESS=
DOTIFY_CHAIN_ID=420420417

# Master secret for content-key derivation (used by /api/uploads/audio for AES-256-GCM encryption).
# Must be at least 32 random bytes encoded as hex. Never expose this value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_KEY_MASTER_SECRET=

# Pinata JWT for server-side IPFS pinning (Ticket 02+).
# This token must never appear in frontend env files or be bundled into the Vite build.
# Use a scoped Pinata key with pinFileToIPFS and pinJSONToIPFS permissions only.
PINATA_JWT=
